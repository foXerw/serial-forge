<Application x:Class="SerialForge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SerialForge.App.ViewModels"
             xmlns:views="clr-namespace:SerialForge.App.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <views:ConnectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandPanelViewModel}">
            <views:CommandPanelView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}">
            <views:LogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RawSendViewModel}">
            <views:RawSendView/>
        </DataTemplate>
    </Application.Resources>
</Application>
