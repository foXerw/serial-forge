<Window x:Class="SerialForge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SerialForge.App.ViewModels"
        Title="SerialForge" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ContentControl Grid.Row="0" Content="{Binding Connection}"/>
        <ContentControl Grid.Row="1" Content="{Binding CommandPanel}"/>
        <ContentControl Grid.Row="2" Content="{Binding Log}"/>
    </Grid>
</Window>
