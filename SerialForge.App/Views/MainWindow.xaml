<Window x:Class="SerialForge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SerialForge" Height="600" Width="1000">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="6,4" Background="#F4F4F4" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SerialForge — 串口协议调试" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📖 使用说明" Command="{Binding ShowHelp}" Margin="4,0"/>
                    <Button Content="✎ 编辑协议" Command="{Binding OpenEditor}" Margin="4,0"/>
                    <Button Content="⬆ 固件升级" Command="{Binding OpenUpgrade}" Margin="4,0"/>
                    <Button Content="💾 导出日志" Command="{Binding ExportLog}" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <ContentControl DockPanel.Dock="Top" Content="{Binding RawSend}"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ContentControl Grid.Row="0" Content="{Binding Connection}"/>
            <ContentControl Grid.Row="1" Content="{Binding CommandPanel}"/>
            <ContentControl Grid.Row="2" Content="{Binding Log}"/>
        </Grid>
    </DockPanel>
</Window>
