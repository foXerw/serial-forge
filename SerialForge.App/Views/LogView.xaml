<UserControl x:Class="SerialForge.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4">
        <DockPanel DockPanel.Dock="Top" Margin="2">
            <TextBlock Text="收发日志" FontWeight="Bold" VerticalAlignment="Center"/>
            <CheckBox Content="自动滚动" IsChecked="{Binding AutoScroll}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="重发" Command="{Binding ResendCommand}" Padding="8,1" Margin="0,0,4,0"/>
                <Button Content="清空" Command="{Binding ClearCommand}" Padding="8,1"/>
            </StackPanel>
        </DockPanel>
        <ListView x:Name="LogList" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" FontFamily="Consolas">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsError}" Value="True">
                            <Setter Property="Foreground" Value="#C00"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="时间" Width="90" DisplayMemberBinding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"/>
                    <GridViewColumn Header="方向" Width="40" DisplayMemberBinding="{Binding Direction}"/>
                    <GridViewColumn Header="十六进制" Width="500" DisplayMemberBinding="{Binding Hex}"/>
                    <GridViewColumn Header="文本" Width="200" DisplayMemberBinding="{Binding Ascii}"/>
                    <GridViewColumn Header="详情" Width="400" DisplayMemberBinding="{Binding Detail}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
