<UserControl x:Class="SerialForge.App.Views.CommandPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="4">
        <DockPanel DockPanel.Dock="Top" Margin="2">
            <TextBlock Text="命令：" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Commands}" DisplayMemberPath="Title"
                      SelectedItem="{Binding SelectedCommand}" Margin="8,0,0,0" MinWidth="200"/>
            <Button Content="发送" Command="{Binding Send}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
        </DockPanel>
        <ItemsControl ItemsSource="{Binding Fields}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Name}" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Codec}" Width="60" Foreground="Gray" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsReadOnly}" MinWidth="200"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
