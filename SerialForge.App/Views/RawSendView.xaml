<UserControl x:Class="SerialForge.App.Views.RawSendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:SerialForge.App.Converters"
             xmlns:vm="clr-namespace:SerialForge.App.ViewModels">
    <StackPanel Orientation="Horizontal" Margin="4">
        <TextBlock Text="原始发送：" VerticalAlignment="Center" Margin="2"/>
        <ComboBox SelectedItem="{Binding Mode}" Width="64" Margin="2"
                  ItemsSource="{x:Static vm:RawSendModes.All}"/>
        <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}" Width="280" Margin="2"
                 FontFamily="Consolas" ToolTip="十六进制(如 AA 55) 或 文本，取决于左侧模式"/>
        <ComboBox SelectedItem="{Binding Encoding}" Width="84" Margin="2"
                  Visibility="{Binding IsTextMode, Converter={x:Static c:VisibilityConverter.Instance}}"
                  ItemsSource="{x:Static vm:TextEncodings.All}"/>
        <Button Content="发送" Command="{Binding Send}" Margin="8,2,2,2"/>
    </StackPanel>
</UserControl>
