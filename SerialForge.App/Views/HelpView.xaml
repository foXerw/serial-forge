<Window x:Class="SerialForge.App.Views.HelpView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用说明" Height="680" Width="760">
    <ScrollViewer Padding="16">
        <StackPanel>

            <!-- 1. 快速上手 -->
            <TextBlock Text="一、快速上手" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
            <TextBlock Text="1. 定义协议：点「编辑协议」，按顺序增删帧字段（segment），每个字段标好角色与位宽，再配命令，点「应用」即时生效；也可「打开…」现有 JSON 或「另存为…」。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="2. 连接串口：顶部选端口与波特率，点「连接」。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="3. 选命令填数据：命令下拉后，下方出现可编辑字段；固定/长度/校验字段由引擎自动算。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="4. 发送并观察日志：点「发送」，「收发日志」显示时间戳、方向(TX/RX)、十六进制、ASCII 与按字段解析；坏帧红色标记，不崩溃。" TextWrapping="Wrap" Margin="0,4"/>

            <!-- 2. 核心模型：位段 -->
            <TextBlock Text="二、帧 = 有序位段（segment）" FontWeight="Bold" FontSize="16" Margin="0,12,0,6"/>
            <TextBlock Text="一帧就是一串按顺序排列的「位段」。每个段有：name、role（角色）、width（位宽）。段在帧里的位置 = 前面所有段位宽的累加，位序 MSB-first（位偏移 0 = 最高位）。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="所以「高 4 位=版本、低 4 位=长度」就是两个连续段：ver(width=4) + len(width=4)，自动拼成一个字节。位域不再是特例，就是窄一点的段。" TextWrapping="Wrap" Margin="0,4" FontFamily="Consolas"/>
            <TextBlock Text="整帧所有段位宽之和必须是 8 的倍数（整字节）。变长 payload 段的 width 留空。" TextWrapping="Wrap" Margin="0,4"/>

            <!-- 3. 四种角色 -->
            <TextBlock Text="三、四种角色 role" FontWeight="Bold" FontSize="16" Margin="0,12,0,6"/>
            <TextBlock Text="· fixed：固定字节（前导 AA 55、帧尾），value 填 hex，width 必须等于这些字节的位数。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="· value：可编辑数据（cmd、标志位、payload）。定宽段填 default（整数，落在 width 内）；变长段（payload）width 留空，命令面板里填 hex 或用 payload 子模板。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="· length：自动算长度。counts 填计入的字段名（逗号分隔），长度 = 这些字段总字节数 + offset。一帧至多一个 length；若它数变长 payload，length 必须排在 payload 之前。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="· checksum：自动算校验。algo 选 crc16/crc32/sum8/xor8，over.from/to 填起止段名（闭区间，字节对齐），CRC 再配 poly/init/refIn/refOut/xorOut 五参数。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="字节序：width≥16 且为 8 的倍数的段才设 little/big；留空用协议默认。" TextWrapping="Wrap" Margin="0,4"/>

            <!-- 4. 命令与 payload 子模板 -->
            <TextBlock Text="四、命令与 payload 子模板" FontWeight="Bold" FontSize="16" Margin="0,12,0,6"/>
            <TextBlock Text="命令（command）是命名预设：values 里固定某些 value 段（如 cmd=0x05）。不同命令的 payload 结构不同时，给命令配 payload 子模板——它本身也是一组 segment，打进/解出帧里的那个变长 payload 段。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="示例：writeConfig 的 payload = [id(width=8), value(width=16)]，命令面板会自动展开成 id、value 两行可编辑。" TextWrapping="Wrap" Margin="0,4" FontFamily="Consolas"/>
            <TextBlock Text="payload 子模板在编辑器「原始 JSON」标签页里编辑。" TextWrapping="Wrap" Margin="0,4"/>

            <!-- 5. 原始发送 -->
            <TextBlock Text="五、原始发送" FontWeight="Bold" FontSize="16" Margin="0,12,0,6"/>
            <TextBlock Text="「原始发送」旁路协议引擎直发字节：Hex 模式输十六进制（AA 55）；文本模式按 ASCII/UTF-8/GBK 编码发出，适合 AT 指令、明文。" TextWrapping="Wrap" Margin="0,4"/>

            <!-- 6. 成帧与 JSON 速查 -->
            <TextBlock Text="六、成帧与 JSON 速查" FontWeight="Bold" FontSize="16" Margin="0,12,0,6"/>
            <TextBlock Text="成帧由帧结构自动派生：第一个 fixed 段是前导（流同步），length 段给出帧总长；无前导/长度时回退到超时成帧。" TextWrapping="Wrap" Margin="0,4"/>
            <TextBlock Text="JSON（见 demo-mcu.json）：name/version/defaultByteOrder/frameTimeoutMs + frame[](name/role/width/byteOrder/value/default/enum/counts/offset/algo/over/params) + commands[](name/title/values/payload)。" TextWrapping="Wrap" Margin="0,4" FontFamily="Consolas"/>
            <TextBlock Text="示例帧（demo-mcu）：AA 55 | len(u16le) | cmd(u8) | payload | crc16(u16le)" TextWrapping="Wrap" Margin="0,8" FontFamily="Consolas"/>

        </StackPanel>
    </ScrollViewer>
</Window>
