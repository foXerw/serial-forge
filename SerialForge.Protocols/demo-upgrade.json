{
  "name": "demo-upgrade",
  "version": "1.0",
  "defaultByteOrder": "little",
  "framing": { "mode": "length-prefix", "preamble": ["0xAA","0x55"], "lengthField": "len", "frameTimeoutMs": 50 },
  "layout": [
    { "name": "preamble", "kind": "literal",  "codec": "bytes", "value": ["0xAA","0x55"] },
    { "name": "len",      "kind": "computed", "codec": "u16",   "compute": { "algo": "length", "counts": ["payload"], "params": { "width": 2 } } },
    { "name": "cmd",      "kind": "value",    "codec": "u8" },
    { "name": "payload",  "kind": "value",    "codec": "bytes" },
    { "name": "crc16",    "kind": "computed", "codec": "u16",   "compute": { "algo": "crc16", "over": { "from": "preamble", "to": "payload" }, "params": { "poly":"0x1021","init":"0xFFFF","refIn":false,"refOut":false,"xorOut":"0x0000" } } }
  ],
  "commands": [
    { "name": "startUpgrade",  "title": "开始升级", "fix": { "cmd": "0x10" },
      "payloadFields": [ { "name": "totalSize", "codec": "u32", "default": "0" }, { "name": "totalCrc32", "codec": "u32", "default": "0" } ] },
    { "name": "transferBlock", "title": "传输块",  "fix": { "cmd": "0x11" },
      "payloadFields": [ { "name": "seq", "codec": "u16", "default": "0" }, { "name": "offset", "codec": "u32", "default": "0" }, { "name": "data", "codec": "bytes", "size": 64 } ] },
    { "name": "endUpgrade",    "title": "结束升级", "fix": { "cmd": "0x12" },
      "payloadFields": [ { "name": "totalCrc32", "codec": "u32", "default": "0" } ] },
    { "name": "upgradeAck",    "title": "升级应答", "fix": { "cmd": "0x06" },
      "payloadFields": [ { "name": "tag", "codec": "u8", "default": "0" }, { "name": "seq", "codec": "u16", "default": "0" } ] }
  ]
}
