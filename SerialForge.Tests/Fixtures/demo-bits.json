{
  "name": "demo-bits",
  "version": "1.0",
  "defaultByteOrder": "little",
  "framing": { "mode": "length-prefix", "preamble": ["0xAA","0x55"], "lengthField": "len", "frameTimeoutMs": 50 },
  "layout": [
    { "name": "preamble", "kind": "literal",  "codec": "bytes", "value": ["0xAA","0x55"] },
    { "name": "len",      "kind": "computed", "codec": "u16",
      "compute": { "algo": "length", "counts": ["payload"], "params": { "width": 2 } } },
    { "name": "cmd",      "kind": "value",    "codec": "u8" },
    { "name": "status",   "kind": "value",    "codec": "u8",
      "bits": [
        { "name": "type",    "offset": 0, "width": 4, "default": "0x1" },
        { "name": "subtype", "offset": 4, "width": 4 }
      ] },
    { "name": "payload",  "kind": "value",    "codec": "bytes" },
    { "name": "crc16",    "kind": "computed", "codec": "u16",
      "compute": { "algo": "crc16", "over": { "from": "preamble", "to": "payload" },
                   "params": { "poly":"0x1021","init":"0xFFFF","refIn":false,"refOut":false,"xorOut":"0x0000" } } }
  ],
  "commands": [
    { "name": "setFlags", "title": "Set Flags", "fix": { "cmd": "0x10" },
      "payloadFields": [
        { "name": "flags", "codec": "u8",
          "bits": [
            { "name": "type",    "offset": 0, "width": 4 },
            { "name": "subtype", "offset": 4, "width": 4 }
          ] },
        { "name": "seq", "codec": "u8", "default": "0" }
      ] }
  ]
}
